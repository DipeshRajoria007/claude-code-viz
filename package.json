{
  "name": "claude-code-viz",
  "version": "0.0.0",
  "description": "Local web dashboard for your Claude Code data (~/.claude) — usage & cost analytics, session replay, activity heatmap. 100% local & read-only.",
  "keywords": [
    "claude",
    "claude-code",
    "visualizer",
    "dashboard",
    "usage",
    "analytics",
    "cli"
  ],
  "homepage": "https://github.com/DipeshRajoria007/claude-code-viz#readme",
  "bugs": "https://github.com/DipeshRajoria007/claude-code-viz/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DipeshRajoria007/claude-code-viz.git"
  },
  "license": "MIT",
  "author": "Dipesh Rajoria",
  "type": "module",
  "bin": {
    "claude-code-viz": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && vite build --config web/vite.config.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.25"
  }
}
